---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ChatWidget from "../components/ChatWidget.astro";

interface Props {
  title: string;
  description?: string;
  /** Hide the AI chat widget on this page (defaults to false) */
  hideChat?: boolean;
}

const {
  title,
  description = "Cloudflare Demo Shop — explore the Cloudflare platform",
  hideChat = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-5JTNQT5S");
    </script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Tailwind via CDN (matches legacy pages so the retro vibe is preserved) -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              pine: {
                50: "#f2f7f2",
                100: "#e0ece0",
                200: "#c1d9c1",
                300: "#93bc93",
                400: "#5e975e",
                500: "#2F4F2F",
                600: "#274427",
                700: "#1f381f",
                800: "#192e19",
                900: "#112211",
              },
              silver: {
                50: "#F5F5F5",
                100: "#E5E5E5",
                200: "#D4D4D4",
                300: "#A3A3A3",
              },
            },
            fontFamily: {
              sans: ["Inter", "system-ui", "sans-serif"],
              mono: ["Courier New", "Courier", "monospace"],
              retro: ["Times New Roman", "Times", "serif"],
            },
          },
        },
      };
    </script>

    <!-- Alpine.js for interactivity (chat widget, demo controls) -->
    <script
      is:inline
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-silver-50 text-gray-800 font-sans min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-5JTNQT5S"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <Header />

    <slot />

    <Footer />

    {!hideChat && <ChatWidget />}
  </body>
</html>
