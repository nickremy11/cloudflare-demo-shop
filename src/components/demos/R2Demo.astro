---
// Cloud storage demo with a three-way selector:
//   • R2 — object storage: guest upload (email + file) with malicious-content
//     scanning, plus a live R2-vs-S3/GCS/Azure/Vercel pricing calculator.
//   • KV — global key-value store: Set / Get / Delete / List against DEMO_KV
//     (demo-kv: prefix). Shows instant edge reads + global propagation.
//   • D1 — serverless SQL: preset parameterized queries against a seeded
//     products table, echoing the SQL and rows-read for teaching.
//
// R2 upload constraints: 50MB max; allowed pdf, csv, png, jpg, jpeg, gif,
// doc, docx, ppt, pptx, txt. Server scans the full buffer.
//
// Pricing data is hardcoded; the verified date is shown on the page.
// No authentication — uploads are guest-only (email is for attribution).
---

<div x-data="storageDemo()" x-init="init()" class="space-y-6">
  <!-- ─────────────────── Product selector tabs ─────────────────── -->
  <div class="flex flex-wrap gap-2 border-b border-silver-200">
    <button type="button" @click="setTab('r2')" :class="tabClass('r2')">
      R2 — Object Storage
    </button>
    <button type="button" @click="setTab('kv')" :class="tabClass('kv')">
      KV — Key-Value
    </button>
    <button type="button" @click="setTab('d1')" :class="tabClass('d1')">
      D1 — SQL
    </button>
  </div>

  <!-- ═══════════════════════ R2 PANEL ═══════════════════════ -->
  <div x-show="activeTab === 'r2'" class="space-y-8">
    <p class="text-sm text-gray-600">
      R2 is S3-compatible object storage with <strong>$0 egress</strong>. Upload a
      file below (as a guest — your email just tags the file), then use the
      calculator to compare R2's bill against the hyperscalers on a read-heavy
      workload.
    </p>

    <!-- ── Upload ── -->
    <div>
      <h3 class="text-sm font-semibold text-pine-700 uppercase tracking-wide mb-2">
        1. Upload to R2
      </h3>
      <p class="text-sm text-gray-600 mb-4">
        Every file is scanned for malicious content before it's accepted.
        Max 50&nbsp;MB. Allowed types: PDF, CSV, PNG, JPG, GIF, DOC(X), PPT(X), TXT.
      </p>

      <div class="grid md:grid-cols-2 gap-4">
        <div class="demo-panel">
          <h3>Your email</h3>
          <input
            type="email"
            x-model="guestEmail"
            class="demo-input mt-2"
            placeholder="you@example.com"
          />
          <p class="text-xs text-gray-500 mt-2">
            Used only to tag the upload so it can be attributed to you.
          </p>
        </div>

        <div class="demo-panel">
          <h3>Choose a file</h3>
          <input
            type="file"
            @change="onFileChange"
            accept=".pdf,.csv,.png,.jpg,.jpeg,.gif,.doc,.docx,.ppt,.pptx,.txt"
            class="block w-full text-sm text-gray-700 mt-2"
          />
          <p class="text-xs text-gray-500 mt-2" x-show="selectedFile">
            Selected: <strong x-text="selectedFile?.name"></strong>
            (<span x-text="formatBytes(selectedFile?.size ?? 0)"></span>)
          </p>
        </div>
      </div>

      <button type="button" @click="upload" :disabled="!canUpload" class="btn-primary mt-4">
        <span x-show="!uploading">Upload to R2</span>
        <span x-show="uploading">Scanning &amp; uploading...</span>
      </button>

      <div x-show="uploadResult" x-transition class="mt-4 demo-panel" :class="uploadResult?.success ? 'safe' : 'danger'">
        <h3 x-text="uploadResult?.title"></h3>
        <p class="text-sm" x-text="uploadResult?.message"></p>
        <template x-if="uploadResult?.detail">
          <pre class="code-output text-xs mt-2" x-text="uploadResult.detail"></pre>
        </template>
      </div>
    </div>

    <!-- ── Pricing calculator ── -->
    <div>
      <h3 class="text-sm font-semibold text-pine-700 uppercase tracking-wide mb-2">
        2. Pricing calculator: R2 vs the rest
      </h3>
      <p class="text-sm text-gray-600 mb-4">
        Estimate monthly cost for a given workload. R2 has $0 egress —
        the dramatic differentiator on read-heavy workloads.
      </p>

      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="text-xs text-gray-600 block mb-1">Storage (TB)</label>
          <input type="range" x-model.number="calc.storageTB" min="0.1" max="500" step="0.1" class="w-full" />
          <div class="text-sm">
            <input type="number" x-model.number="calc.storageTB" min="0" step="0.1" class="demo-input w-32 inline-block" />
            <span class="text-gray-500"> TB stored</span>
          </div>
        </div>
        <div>
          <label class="text-xs text-gray-600 block mb-1">Egress (TB / month read out)</label>
          <input type="range" x-model.number="calc.egressTB" min="0" max="500" step="0.1" class="w-full" />
          <div class="text-sm">
            <input type="number" x-model.number="calc.egressTB" min="0" step="0.1" class="demo-input w-32 inline-block" />
            <span class="text-gray-500"> TB egressed</span>
          </div>
        </div>
        <div>
          <label class="text-xs text-gray-600 block mb-1">Class A operations (writes, lists) / month</label>
          <input type="number" x-model.number="calc.classAOpsMillions" min="0" step="0.1" class="demo-input" />
          <p class="text-xs text-gray-500 mt-1">In millions. Writes &amp; lists.</p>
        </div>
        <div>
          <label class="text-xs text-gray-600 block mb-1">Class B operations (reads) / month</label>
          <input type="number" x-model.number="calc.classBOpsMillions" min="0" step="0.1" class="demo-input" />
          <p class="text-xs text-gray-500 mt-1">In millions. Reads (GET, HEAD).</p>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-pine-50">
              <th class="text-left p-2 font-semibold text-pine-700">Provider</th>
              <th class="text-right p-2 font-semibold text-pine-700">Storage</th>
              <th class="text-right p-2 font-semibold text-pine-700">Egress</th>
              <th class="text-right p-2 font-semibold text-pine-700">Operations</th>
              <th class="text-right p-2 font-semibold text-pine-700">Total / mo</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="row in costs" :key="row.name">
              <tr class="border-b border-silver-100" :class="row.name === 'Cloudflare R2' ? 'bg-pine-50/50' : ''">
                <td class="p-2 font-medium" x-text="row.name"></td>
                <td class="p-2 text-right font-mono text-xs" x-text="'$' + row.storage.toFixed(2)"></td>
                <td class="p-2 text-right font-mono text-xs" :class="row.egress === 0 ? 'text-pine-600 font-semibold' : ''" x-text="'$' + row.egress.toFixed(2)"></td>
                <td class="p-2 text-right font-mono text-xs" x-text="'$' + row.operations.toFixed(2)"></td>
                <td class="p-2 text-right font-mono font-semibold" :class="row.name === 'Cloudflare R2' ? 'text-pine-700' : ''" x-text="'$' + row.total.toFixed(2)"></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>

      <p class="text-xs text-gray-500 mt-3">
        <strong>Pricing verified June 2026.</strong> Standard storage tiers,
        US regions. Hyperscaler egress and ops pricing varies by region &amp;
        tier; figures reflect commonly-cited public list prices. R2 egress is
        $0 to any internet destination, billed only for storage and operations.
      </p>
    </div>
  </div>

  <!-- ═══════════════════════ KV PANEL ═══════════════════════ -->
  <div x-show="activeTab === 'kv'" class="space-y-6">
    <p class="text-sm text-gray-600">
      Workers KV is a <strong>global key-value store</strong>. Writes propagate to
      every Cloudflare location within seconds; reads are served from the cache
      nearest the user. Reach for KV when you have a flat key&nbsp;→&nbsp;value lookup
      and want the fastest possible global reads: config, feature flags, session
      tokens, cached API responses.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <div class="demo-panel">
        <h3>Key</h3>
        <input type="text" x-model="kv.key" class="demo-input mt-2" placeholder="feature-flag:new-checkout" />
        <h3 class="mt-3">Value</h3>
        <input type="text" x-model="kv.value" class="demo-input mt-2" placeholder="enabled" />
        <div class="flex flex-wrap gap-2 mt-3">
          <button type="button" @click="kvSet" class="btn-primary text-xs">Set</button>
          <button type="button" @click="kvGet" class="btn-secondary text-xs">Get</button>
          <button type="button" @click="kvDelete" class="btn-danger text-xs">Delete</button>
        </div>
        <div x-show="kv.result" x-transition class="mt-3 text-sm" :class="kv.result?.ok ? 'text-pine-700' : 'text-red-600'">
          <span x-text="kv.result?.text"></span>
        </div>
      </div>

      <div class="demo-panel">
        <div class="flex items-center justify-between">
          <h3>Keys in the store</h3>
          <button type="button" @click="kvList" class="text-xs text-pine-600 hover:underline">
            <span x-show="!kv.loading">↻ Refresh</span>
            <span x-show="kv.loading">Loading...</span>
          </button>
        </div>
        <div x-show="kv.list.length === 0 && !kv.loading" class="text-sm text-gray-500 mt-2">
          No keys yet. Set one on the left.
        </div>
        <div class="space-y-1 mt-2">
          <template x-for="entry in kv.list" :key="entry.key">
            <div class="flex items-center justify-between gap-2 text-sm bg-white border border-silver-100 rounded px-2 py-1">
              <code class="text-xs text-pine-700 truncate" x-text="entry.key"></code>
              <span class="text-xs text-gray-500 truncate" x-text="entry.value"></span>
            </div>
          </template>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════ D1 PANEL ═══════════════════════ -->
  <div x-show="activeTab === 'd1'" class="space-y-6">
    <p class="text-sm text-gray-600">
      D1 is a <strong>serverless SQL database</strong> (SQLite-compatible) that runs
      at the edge. Reach for D1 when you need relational queries, joins, or
      transactions. Run a preset query against a seeded <code>products</code> table —
      the exact SQL and rows-read are shown so you can see what D1 did.
    </p>

    <div class="flex flex-wrap gap-2">
      <button type="button" @click="d1Query('all')" :class="d1BtnClass('all')">All products</button>
      <button type="button" @click="d1Query('by_category', 'category=Audio')" :class="d1BtnClass('by_category')">Category = Audio</button>
      <button type="button" @click="d1Query('under_price', 'price=50')" :class="d1BtnClass('under_price')">Price &lt; $50</button>
      <button type="button" @click="d1Query('cheapest_per_category')" :class="d1BtnClass('cheapest_per_category')">Cheapest per category</button>
    </div>

    <div x-show="d1.sql" class="demo-panel">
      <h3>Query executed</h3>
      <pre class="code-output text-xs mt-2" x-text="d1.sql"></pre>
      <p class="text-xs text-gray-500 mt-2" x-show="d1.rowsRead !== null">
        Rows read: <strong x-text="d1.rowsRead"></strong> ·
        Rows returned: <strong x-text="d1.rows.length"></strong>
      </p>
    </div>

    <div x-show="d1.error" class="demo-panel danger">
      <h3>Query error</h3>
      <p class="text-sm" x-text="d1.error"></p>
      <p class="text-xs text-gray-500 mt-2">
        If the table doesn't exist yet, seed it once with
        <code>npx wrangler d1 execute demo-d1 --remote --file=db/demo-d1-seed.sql</code>.
      </p>
    </div>

    <div class="overflow-x-auto" x-show="d1.rows.length > 0">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-pine-50">
            <template x-for="col in d1Columns" :key="col">
              <th class="text-left p-2 font-semibold text-pine-700" x-text="col"></th>
            </template>
          </tr>
        </thead>
        <tbody>
          <template x-for="(row, i) in d1.rows" :key="i">
            <tr class="border-b border-silver-100">
              <template x-for="col in d1Columns" :key="col">
                <td class="p-2" :class="col === 'price' ? 'text-right font-mono text-xs' : ''" x-text="d1Cell(col, row[col])"></td>
              </template>
            </tr>
          </template>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script is:inline>
  // ────────────────────────────────────────────────────────────
  //  Pricing constants (USD). Verified June 2026 against each
  //  vendor's public pricing page. R2/S3/GCS/Azure/Vercel unchanged
  //  since the prior Nov 2024 snapshot.
  // ────────────────────────────────────────────────────────────
  const PRICING = {
    "Cloudflare R2": {
      storage_per_gb_month: 0.015,
      egress_per_gb: 0,
      classA_per_million: 4.5,  // writes, lists, etc.
      classB_per_million: 0.36, // reads
    },
    "AWS S3 (Standard)": {
      storage_per_gb_month: 0.023,
      egress_per_gb: 0.09,      // first 10TB tier
      classA_per_million: 5.0,
      classB_per_million: 0.4,
    },
    "Google Cloud Storage (Standard)": {
      storage_per_gb_month: 0.020,
      egress_per_gb: 0.12,      // egress to internet, typical
      classA_per_million: 5.0,
      classB_per_million: 0.4,
    },
    "Azure Blob (Hot)": {
      storage_per_gb_month: 0.018,
      egress_per_gb: 0.087,
      classA_per_million: 6.5,
      classB_per_million: 0.5,
    },
    "Vercel Blob": {
      storage_per_gb_month: 0.023,
      egress_per_gb: 0.05,
      classA_per_million: 5.0,
      classB_per_million: 0.4,
    },
  };

  function storageDemo() {
    return {
      // ── Tabs
      activeTab: "r2",

      // ── R2 upload
      guestEmail: "",
      selectedFile: null,
      uploading: false,
      uploadResult: null,

      // ── R2 calculator
      calc: { storageTB: 10, egressTB: 50, classAOpsMillions: 1, classBOpsMillions: 100 },

      // ── KV
      kv: { key: "", value: "", result: null, list: [], loading: false, loaded: false },

      // ── D1
      d1: { rows: [], sql: "", rowsRead: null, error: null, loading: false, loaded: false, activePreset: "" },

      init() {
        // Panels load lazily the first time their tab is opened (see setTab).
      },

      setTab(tab) {
        this.activeTab = tab;
        if (tab === "kv" && !this.kv.loaded) { this.kv.loaded = true; this.kvList(); }
        if (tab === "d1" && !this.d1.loaded) { this.d1.loaded = true; this.d1Query("all"); }
      },

      tabClass(tab) {
        return this.activeTab === tab
          ? "px-4 py-2 text-sm font-semibold text-pine-700 border-b-2 border-pine-600 -mb-px"
          : "px-4 py-2 text-sm font-medium text-gray-500 hover:text-pine-600 border-b-2 border-transparent -mb-px";
      },

      // ── Shared: parse JSON, but detect HTML (WAF/security block) gracefully
      async parseJson(res) {
        const ctype = res.headers.get("content-type") || "";
        if (!ctype.includes("application/json")) {
          return {
            __nonJson: true,
            error: `Server returned ${res.status} ${res.statusText || ""} as ${ctype || "an unknown type"} instead of JSON — a WAF or security rule may be intercepting this request.`,
          };
        }
        try { return await res.json(); } catch { return { error: "Invalid JSON response from server." }; }
      },

      formatBytes(bytes) {
        if (!bytes) return "0 B";
        const units = ["B", "KB", "MB", "GB"];
        let i = 0;
        let n = bytes;
        while (n >= 1024 && i < units.length - 1) { n /= 1024; i++; }
        return n.toFixed(n < 10 ? 1 : 0) + " " + units[i];
      },

      // ───────────────────────── R2 ─────────────────────────
      onFileChange(e) {
        this.selectedFile = e.target.files?.[0] ?? null;
        this.uploadResult = null;
      },

      get canUpload() {
        if (!this.selectedFile || this.uploading) return false;
        return /\S+@\S+\.\S+/.test(this.guestEmail);
      },

      async upload() {
        if (!this.canUpload) return;
        this.uploading = true;
        this.uploadResult = null;
        try {
          const form = new FormData();
          form.append("file", this.selectedFile);
          form.append("guestEmail", this.guestEmail);
          const res = await fetch("/api/r2/upload", { method: "POST", body: form });

          // A WAF/security block returns an HTML page, not JSON — detect it
          // so the user sees a real explanation instead of a JSON parse error.
          const ctype = res.headers.get("content-type") || "";
          if (!ctype.includes("application/json")) {
            this.uploadResult = {
              success: false,
              title: "✗ Upload blocked before it reached R2",
              message: `The server returned ${res.status} ${res.statusText || ""} as ${ctype || "an unknown type"} instead of JSON. A WAF or security rule is likely intercepting POST /api/r2/upload — add a WAF skip/allow rule for that path.`,
            };
            return;
          }

          const data = await res.json();
          if (res.ok && data.success) {
            this.uploadResult = {
              success: true,
              title: "✓ Upload successful",
              message: `File ${data.filename} (${this.formatBytes(data.size)}) stored in R2. Scan: ${data.scanStatus ?? "clean"}.`,
              detail: data.scanDetails ? JSON.stringify(data.scanDetails, null, 2) : null,
            };
            this.selectedFile = null;
            const fileInput = document.querySelector("input[type=file]");
            if (fileInput) fileInput.value = "";
          } else {
            this.uploadResult = {
              success: false,
              title: data.scanStatus === "malicious" ? "⚠ Malicious file blocked" : "✗ Upload rejected",
              message: data.error || "Upload failed.",
              detail: data.scanDetails ? JSON.stringify(data.scanDetails, null, 2) : null,
            };
          }
        } catch (e) {
          this.uploadResult = { success: false, title: "Network error", message: e?.message ?? String(e) };
        } finally {
          this.uploading = false;
        }
      },

      get costs() {
        const storageGB = this.calc.storageTB * 1024;
        const egressGB = this.calc.egressTB * 1024;
        const opsA = this.calc.classAOpsMillions;
        const opsB = this.calc.classBOpsMillions;
        return Object.entries(PRICING).map(([name, p]) => {
          const storage = storageGB * p.storage_per_gb_month;
          const egress = egressGB * p.egress_per_gb;
          const operations = opsA * p.classA_per_million + opsB * p.classB_per_million;
          return { name, storage, egress, operations, total: storage + egress + operations };
        });
      },

      // ───────────────────────── KV ─────────────────────────
      async kvList() {
        this.kv.loading = true;
        try {
          const res = await fetch("/api/kv/demo");
          const data = await this.parseJson(res);
          this.kv.list = data.keys ?? [];
        } catch {}
        this.kv.loading = false;
      },

      async kvSet() {
        const key = this.kv.key.trim();
        if (!key) { this.kv.result = { ok: false, text: "Enter a key first." }; return; }
        this.kv.result = null;
        const res = await fetch("/api/kv/demo/" + encodeURIComponent(key), {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ value: this.kv.value }),
        });
        const data = await this.parseJson(res);
        this.kv.result = res.ok && data.success
          ? { ok: true, text: `SET "${key}" = "${data.value}" — now propagating to every Cloudflare location.` }
          : { ok: false, text: data.error || "Set failed." };
        this.kvList();
      },

      async kvGet() {
        const key = this.kv.key.trim();
        if (!key) { this.kv.result = { ok: false, text: "Enter a key first." }; return; }
        this.kv.result = null;
        const res = await fetch("/api/kv/demo/" + encodeURIComponent(key));
        const data = await this.parseJson(res);
        if (!res.ok) { this.kv.result = { ok: false, text: data.error || "Get failed." }; return; }
        this.kv.result = data.found
          ? { ok: true, text: `GET "${key}" → "${data.value}" (served from the nearest edge cache)` }
          : { ok: false, text: `GET "${key}" → null (key not found)` };
      },

      async kvDelete() {
        const key = this.kv.key.trim();
        if (!key) { this.kv.result = { ok: false, text: "Enter a key first." }; return; }
        const res = await fetch("/api/kv/demo/" + encodeURIComponent(key), { method: "DELETE" });
        const data = await this.parseJson(res);
        this.kv.result = res.ok && data.success
          ? { ok: true, text: `DELETE "${key}" — removed.` }
          : { ok: false, text: data.error || "Delete failed." };
        this.kvList();
      },

      // ───────────────────────── D1 ─────────────────────────
      d1BtnClass(preset) {
        return this.d1.activePreset === preset ? "btn-primary text-xs" : "btn-secondary text-xs";
      },

      get d1Columns() {
        return this.d1.rows.length ? Object.keys(this.d1.rows[0]) : [];
      },

      d1Cell(col, val) {
        if (col === "price" && typeof val === "number") return "$" + val.toFixed(2);
        return val;
      },

      async d1Query(preset, extra) {
        this.d1.loading = true;
        this.d1.error = null;
        this.d1.activePreset = preset;
        try {
          let url = "/api/d1/demo/query?preset=" + encodeURIComponent(preset);
          if (extra) url += "&" + extra;
          const res = await fetch(url);
          const data = await this.parseJson(res);
          if (!res.ok || data.error) {
            this.d1.error = data.error || "Query failed.";
            this.d1.rows = [];
            this.d1.sql = data.sql || "";
            this.d1.rowsRead = null;
            return;
          }
          this.d1.rows = data.rows ?? [];
          this.d1.sql = data.sql ?? "";
          this.d1.rowsRead = data.rowsRead ?? null;
        } catch (e) {
          this.d1.error = String(e);
        } finally {
          this.d1.loading = false;
        }
      },
    };
  }
</script>
