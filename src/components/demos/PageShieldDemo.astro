---
// PageShieldDemo (v2) — launcher + scenario controls.
//
// The live demo surface is /client-side-security/checkout. That page is a
// dedicated, hand-rolled checkout flow with a tight, stable inventory of
// scripts, connections, and cookies for Client-Side Security to monitor.
// This component lives inside the regular Client-Side Security solution
// page and provides:
//
//   1. A primary launch button to the checkout page.
//   2. Scenario toggles that flip alert scenarios on the checkout page:
//        - new_script   (injects coinhive.min.js)
//        - bad_conn     (fetches an unexpected external host)
//        - bad_cookie   (sets an unexpected cookie)
//        - code_change  (flips checkout-analytics.js v1 <-> v2)
//   3. A reset button that returns everything to baseline.
//
// All toggles are persisted in KV via /api/page-shield/checkout/scenarios
// so any traffic generator (e.g. headless Selenium on a VM) visiting the
// checkout page will see the current state.
---

<div x-data="pageShieldDemo()" x-init="loadState()" class="space-y-5">
  <div class="demo-panel safe">
    <h3 class="!mb-1">Open the live demo</h3>
    <p class="text-sm text-gray-700 mb-3">
      The Client-Side Security demo runs on its own dedicated checkout page so
      that Cloudflare can build a clean inventory of scripts, connections,
      and cookies. Use the scenario toggles below to inject signals, then
      reload the checkout page (or have your traffic generator hit it) to
      trigger alerts.
    </p>
    <div class="flex flex-wrap gap-3 items-center">
      <a
        href="/client-side-security/checkout?pageshieldforcecsp"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Open /client-side-security/checkout ↗
      </a>
      <a
        href="/client-side-security/checkout"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        Open without forced sampling
      </a>
    </div>
  </div>

  <div class="demo-panel">
    <div class="flex items-baseline justify-between mb-2">
      <h3 class="!mb-0">Scenario toggles</h3>
      <span class="text-xs text-gray-500" x-text="loading ? 'updating…' : 'live'"></span>
    </div>
    <p class="text-xs text-gray-500 mb-3">
      Flags are stored in Workers KV and read by the checkout page on every
      load. Toggle, then trigger a fresh page view to surface the signal.
    </p>

    <div class="space-y-3">
      <template x-for="s in scenarios" :key="s.name">
        <div class="flex items-start justify-between gap-3 py-2 border-b border-silver-100 last:border-b-0">
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm" x-text="s.label"></div>
            <div class="text-xs text-gray-500" x-text="s.detail"></div>
            <div class="text-xs text-gray-400 mt-1" x-text="'state: ' + s.state"></div>
          </div>
          <button
            type="button"
            class="btn-primary text-xs"
            :class="s.enabled ? 'btn-danger' : 'btn-primary'"
            @click="toggle(s)"
            :disabled="loading"
            x-text="s.enabled ? 'Disable' : 'Enable'"
          ></button>
        </div>
      </template>
    </div>

    <div class="mt-4 flex gap-3">
      <button
        type="button"
        class="btn-secondary"
        @click="loadState()"
        :disabled="loading"
      >
        Refresh
      </button>
      <button
        type="button"
        class="btn-danger"
        @click="resetAll()"
        :disabled="loading"
      >
        Reset everything to baseline
      </button>
    </div>

    <div x-show="lastMessage" x-transition class="mt-3 text-xs text-gray-600" style="display:none;">
      <span x-text="lastMessage"></span>
    </div>
  </div>

  <div class="demo-panel">
    <h3>What the checkout page emits</h3>
    <p class="text-xs text-gray-500 mb-2">
      The baseline page is intentionally small so the inventory converges.
    </p>
    <ul class="text-sm space-y-1 list-disc pl-5">
      <li><strong>Scripts (first-party):</strong> <code>/api/page-shield/checkout-core.js</code>, <code>/api/page-shield/checkout-analytics.js</code></li>
      <li><strong>Scripts (third-party, trusted):</strong> <code>cdn.jsdelivr.net/npm/jquery</code></li>
      <li><strong>Connections (first-party):</strong> <code>POST /api/page-shield/checkout/submit</code>, <code>POST /api/page-shield/checkout/telemetry</code></li>
      <li><strong>Cookies (Set-Cookie, first-party):</strong> <code>demo_checkout_session</code>, <code>demo_checkout_last_order</code></li>
      <li><strong>Cookies (document.cookie):</strong> <code>demo_cart_seen</code></li>
    </ul>
    <p class="text-xs text-gray-500 mt-2">
      Anything beyond this list is added only by an enabled scenario.
    </p>
  </div>
</div>

<script is:inline>
  function pageShieldDemo() {
    return {
      loading: false,
      lastMessage: "",

      scenarios: [
        {
          name: "new_script",
          label: "New script: coinhive.min.js",
          detail:
            "Injects <script src=\"https://coinhive.com/lib/coinhive.min.js\"> on the checkout page. Triggers New Resource / New Domain alerts; Malicious Script with CSS Advanced.",
          enabled: false,
          state: "unknown",
        },
        {
          name: "bad_conn",
          label: "Unexpected connection",
          detail:
            "Browser fetches an external host not in the connect-src allowlist. Populates Connections monitoring; triggers content security rule violation in log/allow mode.",
          enabled: false,
          state: "unknown",
        },
        {
          name: "bad_cookie",
          label: "Unexpected cookie",
          detail:
            "Sets demo_unauthorized_tracker via document.cookie. Surfaces as a new cookie in Web Assets > Cookies.",
          enabled: false,
          state: "unknown",
        },
        {
          name: "code_change",
          label: "Code change on checkout-analytics.js",
          detail:
            "Flips the served checkout-analytics.js between v1 (clean) and v2 (skimmer payload). Triggers Code Change alert with CSS Advanced.",
          enabled: false,
          state: "unknown",
        },
      ],

      _applyState(data) {
        const setEnabled = (name, val, stateLabel) => {
          const s = this.scenarios.find((x) => x.name === name);
          if (s) {
            s.enabled = !!val;
            s.state = stateLabel;
          }
        };

        setEnabled(
          "new_script",
          data.newScript && data.newScript.enabled,
          data.newScript && data.newScript.enabled ? "ENABLED" : "disabled"
        );
        setEnabled(
          "bad_conn",
          data.badConn && data.badConn.enabled,
          data.badConn && data.badConn.enabled ? "ENABLED" : "disabled"
        );
        setEnabled(
          "bad_cookie",
          data.badCookie && data.badCookie.enabled,
          data.badCookie && data.badCookie.enabled ? "ENABLED" : "disabled"
        );
        setEnabled(
          "code_change",
          data.analyticsVersion === "v2",
          "analytics=" + (data.analyticsVersion || "v1")
        );
      },

      async loadState() {
        this.loading = true;
        try {
          const res = await fetch(
            "/api/page-shield/checkout/scenarios",
            { cache: "no-store" }
          );
          const data = await res.json();
          this._applyState(data);
          this.lastMessage = "State refreshed.";
        } catch (e) {
          this.lastMessage = "Failed to load state: " + (e && e.message);
        } finally {
          this.loading = false;
        }
      },

      async toggle(s) {
        this.loading = true;
        try {
          const res = await fetch(
            "/api/page-shield/checkout/scenarios",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ name: s.name, enabled: !s.enabled }),
            }
          );
          const data = await res.json();
          this.lastMessage =
            "Toggled " + s.name + " -> " + JSON.stringify(data);
          await this.loadState();
        } catch (e) {
          this.lastMessage = "Toggle failed: " + (e && e.message);
        } finally {
          this.loading = false;
        }
      },

      async resetAll() {
        this.loading = true;
        try {
          const res = await fetch("/api/page-shield/checkout/reset", {
            method: "POST",
          });
          const data = await res.json();
          this.lastMessage = "Reset: " + JSON.stringify(data);
          await this.loadState();
        } catch (e) {
          this.lastMessage = "Reset failed: " + (e && e.message);
        } finally {
          this.loading = false;
        }
      },
    };
  }
</script>
