---
// AI chat widget — sticky bottom-right.
// Every message routes through Cloudflare AI Gateway → Llama 3.3 70B.
// The AI Gateway solution page references this widget as a live example.
---

<div x-data="chatBot()" class="fixed bottom-6 right-6 z-50">
  <!-- Minimized launcher -->
  <button
    x-show="!isOpen"
    @click="isOpen = true"
    class="bg-pine-500 hover:bg-pine-600 text-white rounded-full p-4 shadow-lg transition-all hover:scale-105"
    aria-label="Open chat"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
    </svg>
  </button>

  <!-- Expanded chat -->
  <div
    x-show="isOpen"
    x-transition
    style="display: none;"
    class="bg-white rounded-lg shadow-xl w-96 h-[500px] flex flex-col border border-silver-200"
  >
    <div class="bg-pine-500 text-white px-4 py-3 rounded-t-lg flex justify-between items-center">
      <div class="flex flex-col">
        <span class="font-semibold text-sm">Demo Shop Assistant</span>
        <span class="text-[10px] text-pine-200">via Cloudflare AI Gateway</span>
      </div>
      <button @click="isOpen = false" class="hover:text-pine-200" aria-label="Minimize chat">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto p-4 space-y-4" x-ref="messageContainer">
      <template x-for="msg in messages" :key="msg.id">
        <div :class="msg.role === 'user' ? 'text-right' : 'text-left'">
          <div
            :class="msg.role === 'user'
              ? 'bg-pine-500 text-white inline-block px-3 py-2 rounded-lg max-w-[80%]'
              : 'bg-silver-100 text-gray-800 inline-block px-3 py-2 rounded-lg max-w-[80%]'"
          >
            <p x-text="msg.content" class="whitespace-pre-wrap text-sm"></p>
          </div>
        </div>
      </template>
      <div x-show="isLoading" class="text-left">
        <div class="bg-silver-100 inline-block px-3 py-2 rounded-lg">
          <span class="animate-pulse text-sm text-gray-500">Thinking...</span>
        </div>
      </div>
    </div>

    <div class="p-4 border-t border-silver-200">
      <form @submit.prevent="sendMessage" class="flex gap-2">
        <input
          x-model="inputMessage"
          type="text"
          placeholder="Ask about demos or Cloudflare..."
          class="flex-1 px-3 py-2 border border-silver-200 rounded-lg focus:outline-none focus:border-pine-500 text-sm"
          :disabled="isLoading"
        />
        <button
          type="submit"
          class="bg-pine-500 hover:bg-pine-600 text-white px-4 py-2 rounded-lg text-sm font-medium disabled:opacity-50 transition-colors"
          :disabled="isLoading || !inputMessage.trim()"
        >
          Send
        </button>
      </form>
    </div>
  </div>
</div>

<script is:inline>
  function chatBot() {
    return {
      isOpen: false,
      messages: [
        {
          id: 1,
          role: "assistant",
          content:
            "Hi! I can help you find demos or answer Cloudflare questions. What would you like to explore?",
        },
      ],
      inputMessage: "",
      isLoading: false,

      async sendMessage() {
        if (!this.inputMessage.trim() || this.isLoading) return;

        const userMsg = {
          id: Date.now(),
          role: "user",
          content: this.inputMessage,
        };
        this.messages.push(userMsg);
        this.inputMessage = "";
        this.isLoading = true;

        this.$nextTick(() => {
          this.$refs.messageContainer.scrollTop =
            this.$refs.messageContainer.scrollHeight;
        });

        try {
          const response = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              messages: this.messages.map((m) => ({
                role: m.role,
                content: m.content,
              })),
            }),
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || "Request failed");
          }

          const assistantMsg = {
            id: Date.now() + 1,
            role: "assistant",
            content:
              data.choices?.[0]?.message?.content ||
              data.error ||
              "Sorry, I encountered an error.",
          };
          this.messages.push(assistantMsg);
        } catch (error) {
          this.messages.push({
            id: Date.now() + 1,
            role: "assistant",
            content: "Error: " + error.message,
          });
        } finally {
          this.isLoading = false;
          this.$nextTick(() => {
            this.$refs.messageContainer.scrollTop =
              this.$refs.messageContainer.scrollHeight;
          });
        }
      },
    };
  }
</script>
