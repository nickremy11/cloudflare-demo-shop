        <mxCell id="eDcCni" edge="1" parent="1" source="dataCenter" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2F4F2F;strokeWidth=2;endArrow=classic;fontSize=11;fontColor=#1f381f;" target="cniBox" value="Cross-connect / partner circuit&lt;br&gt;(no public Internet)">
