        </mxCell>
        <mxCell id="legendLabel3" parent="1" style="text;fontSize=11;fontColor=#6b7280;html=1;align=left;fontStyle=2;" value="Best for high-bandwidth, latency-sensitive, or compliance-driven connectivity where Internet-based IPsec/GRE isn&#39;t sufficient." vertex="1">
