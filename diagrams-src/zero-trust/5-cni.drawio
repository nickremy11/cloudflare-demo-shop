        <mxCell id="eCniCloud" edge="1" parent="1" source="cniBox" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2F4F2F;dashed=1;endArrow=none;" target="cloudCni">
          <mxGeometry relative="1" as="geometry" />
