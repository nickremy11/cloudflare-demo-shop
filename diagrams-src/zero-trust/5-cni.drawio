        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#374151;align=left;spacingLeft=10;spacingTop=6;" value="Legend" vertex="1">
          <mxGeometry height="140" width="640" x="40" y="323" as="geometry" />
