        <mxCell id="eNearestWan" edge="1" parent="1" source="nearestDc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2F4F2F;strokeWidth=2;endArrow=classic;fontSize=11;fontColor=#1f381f;" target="wanHub" value="Anycast onto Cloudflare backbone">
