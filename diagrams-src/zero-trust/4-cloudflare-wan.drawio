  <diagram id="cf-wan-1" name="Cloudflare WAN">
    <mxGraphModel dx="1348" dy="791" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0" />
