        <mxCell id="title" parent="1" style="text;fontSize=22;fontStyle=1;fontColor=#1a1a1a;html=1;" value="Cloudflare WAN — Global Backbone Replacing MPLS &amp; SD-WAN" vertex="1">
          <mxGeometry height="30" width="800" x="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;fontSize=12;fontColor=#6b7280;html=1;" value="Branches, data centers, cloud VPCs, and remote users all connect to one global network — with Network Firewall, Gateway, and Cloudflare One policy applied to every packet." vertex="1">
