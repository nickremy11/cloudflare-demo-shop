        <mxCell id="wanAnnotation" parent="1" style="text;fontSize=11;fontColor=#5e975e;align=center;html=1;" value="Any-to-any: branch ↔ branch, branch ↔ cloud, branch ↔ remote user — all through one network, one policy set." vertex="1">
