        </mxCell>
        <mxCell id="branchAppliance" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#64748b;fontColor=#1f2937;fontSize=12;" value="Branch Office A&lt;br&gt;+ Cloudflare One Appliance&lt;br&gt;(hardware or virtual)" vertex="1">
