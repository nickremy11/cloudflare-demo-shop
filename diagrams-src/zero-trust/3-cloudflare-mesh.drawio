<mxfile host="app.diagrams.net">
  <diagram id="cf-mesh-1" name="Cloudflare Mesh">
    <mxGraphModel dx="1348" dy="791" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;fontSize=22;fontStyle=1;fontColor=#1a1a1a;html=1;" value="Cloudflare Mesh — Any-to-Any Private Connectivity" vertex="1">
          <mxGeometry height="30" width="700" x="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;fontSize=12;fontColor=#6b7280;html=1;" value="Every enrolled device and node gets a private Mesh IP. Any participant can reach any other — including client-to-client and service-initiated connections — with Gateway policy applied to every hop." vertex="1">
          <mxGeometry height="18" width="1100" x="40" y="32" as="geometry" />
        </mxCell>
        <mxCell id="hub" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0ece0;strokeColor=#2F4F2F;fontColor=#1f381f;fontSize=13;fontStyle=1;" value="Cloudflare Network&lt;br&gt;Mesh IPs + Gateway Policy&lt;br&gt;(Mesh nodes, formerly WARP Connector)" vertex="1">
          <mxGeometry height="120" width="280" x="590" y="240" as="geometry" />
        </mxCell>
        <mxCell id="userLaptop1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#64748b;fontColor=#1f2937;fontSize=12;" value="User Laptop&lt;br&gt;(Cloudflare One Client)" vertex="1">
          <mxGeometry height="70" width="180" x="80" y="90" as="geometry" />
        </mxCell>
        <mxCell id="meshNodeOnPrem" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#64748b;fontColor=#1f2937;fontSize=12;" value="Mesh Node&lt;br&gt;(On-Prem Linux Server)" vertex="1">
