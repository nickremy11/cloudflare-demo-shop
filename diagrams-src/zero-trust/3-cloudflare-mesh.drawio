        </mxCell>
        <mxCell id="cloudVM" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#64748b;fontColor=#1f2937;fontSize=12;" value="Cloud VM&lt;br&gt;(Mesh Node — AWS / Azure / GCP)" vertex="1">
          <mxGeometry height="70" width="180" x="80" y="430" as="geometry" />
        </mxCell>
        <mxCell id="adServer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#64748b;fontColor=#1f2937;fontSize=12;" value="AD / SCCM Server&lt;br&gt;(Corporate IT)" vertex="1">
